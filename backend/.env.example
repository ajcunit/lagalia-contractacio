# ============================================
# LicitIA v2 — Configuració d'Entorn
# ============================================
# COPIA aquest fitxer com a .env i omple els valors.
# Les variables marcades [OBLIGATORI] han d'existir.

# [OBLIGATORI] Base de dades PostgreSQL
DATABASE_URL=postgresql://licitia_user:CANVIA_AQUESTA_CONTRASENYA@localhost:5432/licitia

# [OBLIGATORI] Clau secreta per JWT (es genera automàticament si buida, però defineix-la per producció)
# Genera una amb: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (format JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# IA - Gemini (opcional)
GEMINI_API_KEY=

# IA - Ollama (opcional)
OLLAMA_URL=http://localhost:11434

# Rate Limits
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_EXTERNAL_SYNC=10/minute
RATE_LIMIT_EXTERNAL_AI=30/minute
RATE_LIMIT_EXTERNAL_PROXY=10/minute

# Debug (mai true en producció!)
DEBUG=false
